#!/bin/sh

MODULE_ROOT="/system/suvos/modules/graphics"
MODULE_ORDER="/system/suvos/modules/graphics.order"

if [ ! -r "$MODULE_ORDER" ]; then
  echo "suvos-graphics: module order file is missing"
  exit 0
fi

echo "suvos-graphics: loading graphics/input/audio modules"

while IFS= read -r module; do
  [ -n "$module" ] || continue
  module_path="$MODULE_ROOT/$module"
  if [ ! -r "$module_path" ]; then
    echo "suvos-graphics: missing module: $module"
    continue
  fi
  insmod "$module_path" 2>/tmp/suvos-insmod.err || {
    error="$(cat /tmp/suvos-insmod.err 2>/dev/null || true)"
    case "$error" in
      *"File exists"*|*"already loaded"*) ;;
      *) echo "suvos-graphics: insmod $module: $error" ;;
    esac
  }
done <"$MODULE_ORDER"

for _ in 1 2 3 4 5; do
  [ -e /dev/fb0 ] && {
    echo "suvos-graphics: framebuffer ready: /dev/fb0"
    exit 0
  }
  sleep 1
done

echo "suvos-graphics: framebuffer is still unavailable"
exit 0
