#!/bin/sh

set -u

PATH=/system/suvos/bin:/opt/suvos/bin:/bin:/sbin:/usr/bin:/usr/sbin
export PATH

case "${1:-}" in
  deconfig)
    ifconfig "$interface" 0.0.0.0 2>/dev/null || true
    ;;
  renew|bound)
    if [ -n "${ip:-}" ]; then
      ifconfig "$interface" "$ip" netmask "${subnet:-255.255.255.0}" up
    fi

    route del default dev "$interface" >/dev/null 2>&1 || true
    for router_item in ${router:-}; do
      route add default gw "$router_item" dev "$interface" >/dev/null 2>&1 || true
      break
    done

    if [ -n "${dns:-}" ]; then
      {
        for dns_item in $dns; do
          printf 'nameserver %s\n' "$dns_item"
        done
      } >/etc/resolv.conf
    fi
    ;;
esac

exit 0
