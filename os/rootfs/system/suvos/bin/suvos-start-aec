#!/bin/sh
set -u

cmdline_value() {
  key="$1"
  for arg in $(cat /proc/cmdline 2>/dev/null || true); do
    case "$arg" in
      "$key"=*)
        printf '%s\n' "${arg#*=}"
        return 0
        ;;
    esac
  done
  return 0
}

AEC_ROOT="${SUVOS_AEC_ROOT:-/system/suvos/aec}"
AEC_BIN="${SUVOS_AEC_BIN:-$AEC_ROOT/bin/admin-explorer-code-server}"
AEC_HOST="${SUVOS_AEC_HOST:-127.0.0.1}"
AEC_PORT="${SUVOS_AEC_PORT:-3030}"
AEC_BASE_PATH="${SUVOS_AEC_BASE_PATH:-/aec}"
AEC_DATA="${SUVOS_AEC_DATA:-/data/suvos/aec}"
AEC_EXTENSIONS="${SUVOS_AEC_EXTENSIONS:-/data/suvos/extensions/aec}"
AEC_RUN="${SUVOS_AEC_RUN:-/run/suvos-aec}"
AEC_WORKSPACE_DIR="$AEC_DATA/workspaces"
AEC_WORKSPACE_FILE="$AEC_WORKSPACE_DIR/suvos-root.code-workspace"
AEC_USER_DATA="$AEC_DATA/user-data"
AEC_SERVER_DATA="$AEC_DATA/server-data"
AEC_LOGS="$AEC_DATA/logs"
AEC_EXTENSION_DOWNLOADS="$AEC_DATA/extension-downloads"
AEC_TERMINAL_GPU="${SUVOS_AEC_TERMINAL_GPU:-$(cmdline_value suvos.aec_terminal_gpu)}"
[ -n "$AEC_TERMINAL_GPU" ] || AEC_TERMINAL_GPU=off

case "$AEC_TERMINAL_GPU" in
  auto|on|off) ;;
  *)
    echo "suvos-aec: unsupported terminal GPU mode: $AEC_TERMINAL_GPU"
    exit 2
    ;;
esac

echo "suvos-aec: preparing runtime"

if [ ! -x "$AEC_BIN" ]; then
  echo "suvos-aec: executable is missing: $AEC_BIN"
  exit 1
fi

mkdir -p "$AEC_DATA" "$AEC_EXTENSIONS" "$AEC_RUN" "$AEC_WORKSPACE_DIR" \
  "$AEC_USER_DATA/User" "$AEC_USER_DATA/Machine" "$AEC_SERVER_DATA" \
  "$AEC_LOGS" "$AEC_EXTENSION_DOWNLOADS"
chmod 0700 "$AEC_DATA" "$AEC_RUN"
chmod 0755 "$AEC_EXTENSIONS"

cat >"$AEC_WORKSPACE_FILE" <<EOF
{
  "folders": [
    { "path": "/" },
    { "path": "/system/suvos" },
    { "path": "/data/suvos" },
    { "path": "/tmp" }
  ],
  "settings": {
    "files.exclude": {
      "/proc": true,
      "/sys": true,
      "/dev": true,
      "/run": true
    },
    "extensions.autoCheckUpdates": false,
    "extensions.autoUpdate": false,
    "extensions.ignoreRecommendations": true,
    "telemetry.telemetryLevel": "off",
    "terminal.integrated.cwd": "/",
    "terminal.integrated.defaultProfile.linux": "sh",
    "terminal.integrated.gpuAcceleration": "$AEC_TERMINAL_GPU",
    "terminal.integrated.initialHint": false,
    "terminal.integrated.profiles.linux": {
      "sh": {
        "path": "/bin/sh"
      }
    },
    "terminal.integrated.suggest.enabled": false,
    "update.mode": "none",
    "workbench.enableExperiments": false,
    "workbench.iconTheme": "vs-seti",
    "workbench.startupEditor": "none"
  }
}
EOF

cat >"$AEC_USER_DATA/Machine/settings.json" <<EOF
{
  "extensions.autoCheckUpdates": false,
  "extensions.autoUpdate": false,
  "extensions.confirmedUriHandlerExtensionIds": [],
  "extensions.ignoreRecommendations": true,
  "settingsSync.ignoredSettings": ["*"],
  "settingsSync.keybindingsPerPlatform": false,
  "telemetry.telemetryLevel": "off",
  "terminal.integrated.defaultProfile.linux": "sh",
  "terminal.integrated.gpuAcceleration": "$AEC_TERMINAL_GPU",
  "terminal.integrated.initialHint": false,
  "terminal.integrated.profiles.linux": {
    "sh": {
      "path": "/bin/sh"
    }
  },
  "terminal.integrated.suggest.enabled": false,
  "update.mode": "none",
  "workbench.enableExperiments": false,
  "workbench.iconTheme": "vs-seti",
  "workbench.startupEditor": "none"
}
EOF
cp "$AEC_USER_DATA/Machine/settings.json" "$AEC_USER_DATA/User/settings.json"

cat >"$AEC_RUN/status" <<EOF
starting
host=$AEC_HOST
port=$AEC_PORT
base_path=$AEC_BASE_PATH
EOF

export HOME=/root
export USER=root
export LOGNAME=root
export SHELL=/bin/sh
export PATH=/system/suvos/bin:/opt/suvos/bin:/bin:/sbin:/usr/bin:/usr/sbin

echo "suvos-aec: starting Admin Explorer Code on $AEC_HOST:$AEC_PORT$AEC_BASE_PATH"
echo "suvos-aec: workspace=$AEC_WORKSPACE_FILE"
echo "suvos-aec: terminal gpu=$AEC_TERMINAL_GPU"

exec "$AEC_BIN" \
  --host "$AEC_HOST" \
  --port "$AEC_PORT" \
  --server-base-path "$AEC_BASE_PATH" \
  --without-connection-token \
  --accept-server-license-terms \
  --user-data-dir "$AEC_USER_DATA" \
  --server-data-dir "$AEC_SERVER_DATA" \
  --extensions-dir "$AEC_EXTENSIONS" \
  --extensions-download-dir "$AEC_EXTENSION_DOWNLOADS" \
  --default-workspace "$AEC_WORKSPACE_FILE" \
  --disable-telemetry \
  --telemetry-level off \
  --disable-experiments \
  --disable-workspace-trust \
  --force-disable-user-env
