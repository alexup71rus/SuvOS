#!/bin/sh

set -eu

SUVOS_WITH_RUNTIMES=1
SUVOS_BUILD_PROFILE=full
if [ -r /system/suvos/config/build.conf ]; then
  . /system/suvos/config/build.conf
fi

cmdline_value() {
  key="$1"
  for arg in $(cat /proc/cmdline 2>/dev/null || true); do
    case "$arg" in
      "$key"=*)
        printf '%s\n' "${arg#*=}"
        return 0
        ;;
    esac
  done
  return 0
}

fetch_or_die() {
  output="$1"
  shift
  if wget -q -O "$output" "$@"; then
    return 0
  fi

  status="$?"
  echo "request failed: $*"
  cat "$output" 2>/dev/null || true
  exit "$status"
}

echo "SUVOS_AUTOTEST_BEGIN"
echo "profile=$SUVOS_BUILD_PROFILE"
echo "pwd=$(pwd)"
suvos ping
suvos status
suvos roles
suvos whoami
suvos auth status
test -r /system/suvos/modules/graphics.order
test -r /system/suvos/modules/graphics/kernel/drivers/gpu/drm/tiny/bochs.ko || \
  test -r /system/suvos/modules/graphics/kernel/drivers/gpu/drm/virtio/virtio-gpu.ko
test -r /system/suvos/modules/network.order
test -r /system/suvos/modules/network/kernel/net/packet/af_packet.ko
test -r /system/suvos/modules/network/kernel/drivers/net/ethernet/intel/e1000/e1000.ko || \
  test -r /system/suvos/modules/network/kernel/drivers/net/virtio_net.ko
suvos-splash --check
test -s /system/suvos/security/root-bootstrap.sha256
test -d /system/suvos/apps/manifest.d
test -S /run/suvosd/control.sock
suvosctl ping
suvosctl whoami
suvosctl list
wget -q -O /tmp/suvos-http-health.out http://suv.os/health
cat /tmp/suvos-http-health.out
grep -q '"ok":true' /tmp/suvos-http-health.out
grep -q '"status":"ok"' /tmp/suvos-http-health.out
grep -q '"service":"suvos-gateway"' /tmp/suvos-http-health.out
grep -q '"suvosdOk":true' /tmp/suvos-http-health.out
grep -q '"uiBundleReady":true' /tmp/suvos-http-health.out
grep -q '"apiSocketAvailable":true' /tmp/suvos-http-health.out
grep -q '"systemRootReadOnly":true' /tmp/suvos-http-health.out
wget -q -O /tmp/suvos-ui-index.out http://suv.os/
grep -q '<title>SuvOS Settings</title>' /tmp/suvos-ui-index.out
wget -q -O /tmp/suvos-ui-js.out http://suv.os/ui/app.js
grep -q '/api/status' /tmp/suvos-ui-js.out
if find /system/suvos/ui -type f -name '*.ts' | grep -q .; then
  echo "typescript UI sources are present in image"
  exit 1
fi
wget -q -O /tmp/suvos-ui-css.out http://suv.os/ui/styles.css
grep -q '.panel' /tmp/suvos-ui-css.out
wget -q -O /tmp/suvos-http-status.out http://suv.os/api/status
cat /tmp/suvos-http-status.out
grep -q '"status":"booted"' /tmp/suvos-http-status.out
grep -q '"systemRootReadOnly":true' /tmp/suvos-http-status.out
grep -q '"apiSocketAvailable":true' /tmp/suvos-http-status.out
wget -q -O /tmp/suvos-http-system-network.out http://suv.os/api/system/network
cat /tmp/suvos-http-system-network.out
grep -q '"ok":true' /tmp/suvos-http-system-network.out
grep -q '"interfaces":' /tmp/suvos-http-system-network.out
wget -q -O /tmp/suvos-http-system-network-config.out http://suv.os/api/system/network/config
cat /tmp/suvos-http-system-network-config.out
grep -q '"ok":true' /tmp/suvos-http-system-network-config.out
fetch_or_die /tmp/suvos-http-system-network-configure.out --post-data='' 'http://suv.os/api/system/network/configure?mode=dhcp'
cat /tmp/suvos-http-system-network-configure.out
grep -q '"ok":true' /tmp/suvos-http-system-network-configure.out
grep -q '"configured":true' /tmp/suvos-http-system-network-configure.out
fetch_or_die /tmp/suvos-http-system-network-reconnect.out --post-data='' http://suv.os/api/system/network/reconnect
cat /tmp/suvos-http-system-network-reconnect.out
grep -q '"ok":true' /tmp/suvos-http-system-network-reconnect.out
if [ "$(cmdline_value suvos.autotest_network)" = "1" ]; then
  network_iface=""
  for candidate in /sys/class/net/*; do
    network_iface="${candidate##*/}"
    [ "$network_iface" = "lo" ] && continue
    break
  done
  test -n "$network_iface"
  test "$network_iface" != "lo"
  fetch_or_die /tmp/suvos-http-system-network-dhcp.out --post-data='' "http://suv.os/api/system/network/configure?mode=dhcp&interface=$network_iface"
  cat /tmp/suvos-http-system-network-dhcp.out
  grep -q '"ok":true' /tmp/suvos-http-system-network-dhcp.out
  grep -q '"applied":true' /tmp/suvos-http-system-network-dhcp.out
  wget -q -O /tmp/suvos-http-system-network-online.out http://suv.os/api/system/network
  cat /tmp/suvos-http-system-network-online.out
  grep -q '"online":true' /tmp/suvos-http-system-network-online.out
fi
wget -q -O /tmp/suvos-http-system-wifi.out http://suv.os/api/system/wifi
cat /tmp/suvos-http-system-wifi.out
grep -q '"ok":true' /tmp/suvos-http-system-wifi.out
wget -q -O /tmp/suvos-http-system-wifi-config.out http://suv.os/api/system/wifi/config
cat /tmp/suvos-http-system-wifi-config.out
grep -q '"ok":true' /tmp/suvos-http-system-wifi-config.out
wget -q -O /tmp/suvos-http-system-wifi-connect.out --post-data='' 'http://suv.os/api/system/wifi/connect?ssid=SuvOS-Test&psk=test-pass'
cat /tmp/suvos-http-system-wifi-connect.out
grep -q '"ok":true' /tmp/suvos-http-system-wifi-connect.out
grep -q '"configured":true' /tmp/suvos-http-system-wifi-connect.out
grep -q '"hasPsk":true' /tmp/suvos-http-system-wifi-connect.out
if grep -q 'test-pass' /tmp/suvos-http-system-wifi-connect.out; then
  echo "wifi PSK leaked through API response"
  exit 1
fi
wget -q -O /tmp/suvos-http-system-wifi-saved.out http://suv.os/api/system/wifi/saved
cat /tmp/suvos-http-system-wifi-saved.out
grep -q '"ok":true' /tmp/suvos-http-system-wifi-saved.out
grep -q '"ssid":"SuvOS-Test"' /tmp/suvos-http-system-wifi-saved.out
if grep -q 'test-pass' /tmp/suvos-http-system-wifi-saved.out; then
  echo "wifi PSK leaked through saved networks API response"
  exit 1
fi
wget -q -O /tmp/suvos-http-system-wifi-disconnect.out --post-data='' http://suv.os/api/system/wifi/disconnect
cat /tmp/suvos-http-system-wifi-disconnect.out
grep -q '"ok":true' /tmp/suvos-http-system-wifi-disconnect.out
wget -q -O /tmp/suvos-http-system-wifi-forget.out --post-data='' http://suv.os/api/system/wifi/forget
cat /tmp/suvos-http-system-wifi-forget.out
grep -q '"ok":true' /tmp/suvos-http-system-wifi-forget.out
wget -q -O /tmp/suvos-http-system-wifi-scan.out http://suv.os/api/system/wifi/scan
cat /tmp/suvos-http-system-wifi-scan.out
grep -q '"ok":true' /tmp/suvos-http-system-wifi-scan.out
grep -q '"networks":' /tmp/suvos-http-system-wifi-scan.out
wget -q -O /tmp/suvos-http-system-battery.out http://suv.os/api/system/battery
cat /tmp/suvos-http-system-battery.out
grep -q '"ok":true' /tmp/suvos-http-system-battery.out
grep -q '"supplies":' /tmp/suvos-http-system-battery.out
wget -q -O /tmp/suvos-http-system-bluetooth.out http://suv.os/api/system/bluetooth
cat /tmp/suvos-http-system-bluetooth.out
grep -q '"ok":true' /tmp/suvos-http-system-bluetooth.out
wget -q -O /tmp/suvos-http-system-bluetooth-devices.out http://suv.os/api/system/bluetooth/devices
cat /tmp/suvos-http-system-bluetooth-devices.out
grep -q '"ok":true' /tmp/suvos-http-system-bluetooth-devices.out
grep -q '"devices":' /tmp/suvos-http-system-bluetooth-devices.out
wget -q -O /tmp/suvos-http-system-brightness.out http://suv.os/api/system/brightness
cat /tmp/suvos-http-system-brightness.out
grep -q '"ok":true' /tmp/suvos-http-system-brightness.out
wget -q -O /tmp/suvos-http-system-audio.out http://suv.os/api/system/audio
cat /tmp/suvos-http-system-audio.out
grep -q '"ok":true' /tmp/suvos-http-system-audio.out
wget -q -O /tmp/suvos-http-system-audio-devices.out http://suv.os/api/system/audio/devices
cat /tmp/suvos-http-system-audio-devices.out
grep -q '"ok":true' /tmp/suvos-http-system-audio-devices.out
grep -q '"outputs":' /tmp/suvos-http-system-audio-devices.out
wget -q -O /tmp/suvos-http-system-audio-test.out --post-data='' http://suv.os/api/system/audio/test
cat /tmp/suvos-http-system-audio-test.out
grep -q '"ok":true' /tmp/suvos-http-system-audio-test.out
wget -q -O /tmp/suvos-http-system-display.out http://suv.os/api/system/display
cat /tmp/suvos-http-system-display.out
grep -q '"ok":true' /tmp/suvos-http-system-display.out
grep -q '"outputs":' /tmp/suvos-http-system-display.out
wget -q -O /tmp/suvos-http-system-render.out http://suv.os/api/system/render
cat /tmp/suvos-http-system-render.out
grep -q '"ok":true' /tmp/suvos-http-system-render.out
grep -q '"renderProfile":' /tmp/suvos-http-system-render.out
wget -q -O /tmp/suvos-http-system-display-configure.out --post-data='' 'http://suv.os/api/system/display/configure?width=1024&height=768&scale=1&orientation=normal'
cat /tmp/suvos-http-system-display-configure.out
grep -q '"ok":true' /tmp/suvos-http-system-display-configure.out
wget -q -O /tmp/suvos-http-system-datetime.out http://suv.os/api/system/datetime
cat /tmp/suvos-http-system-datetime.out
grep -q '"ok":true' /tmp/suvos-http-system-datetime.out
grep -q '"canSet":true' /tmp/suvos-http-system-datetime.out
grep -q '"timezoneManaged":true' /tmp/suvos-http-system-datetime.out
grep -q '"format":' /tmp/suvos-http-system-datetime.out
wget -q -O /tmp/suvos-http-system-network-enable.out --post-data='' http://suv.os/api/system/network/enable
cat /tmp/suvos-http-system-network-enable.out
grep -q '"ok":true' /tmp/suvos-http-system-network-enable.out
wget -q -O /tmp/suvos-http-system-wifi-enable.out --post-data='' http://suv.os/api/system/wifi/enable
cat /tmp/suvos-http-system-wifi-enable.out
grep -q '"ok":true' /tmp/suvos-http-system-wifi-enable.out
wget -q -O /tmp/suvos-http-system-bluetooth-enable.out --post-data='' http://suv.os/api/system/bluetooth/enable
cat /tmp/suvos-http-system-bluetooth-enable.out
grep -q '"ok":true' /tmp/suvos-http-system-bluetooth-enable.out
wget -q -O /tmp/suvos-http-system-bluetooth-scan.out --post-data='' http://suv.os/api/system/bluetooth/scan
cat /tmp/suvos-http-system-bluetooth-scan.out
grep -q '"ok":true' /tmp/suvos-http-system-bluetooth-scan.out
wget -q -O /tmp/suvos-http-system-brightness-set.out --post-data='' 'http://suv.os/api/system/brightness/set?percent=50'
cat /tmp/suvos-http-system-brightness-set.out
grep -q '"ok":true' /tmp/suvos-http-system-brightness-set.out
if wget -q -O /tmp/suvos-http-system-datetime-invalid.out --post-data='' 'http://suv.os/api/system/datetime/set?epoch=bad'; then
  echo "invalid datetime epoch was accepted"
  exit 1
fi
wget -q -O /tmp/suvos-http-system-timezone.out --post-data='' 'http://suv.os/api/system/datetime/timezone?timezone=UTC'
cat /tmp/suvos-http-system-timezone.out
grep -q '"ok":true' /tmp/suvos-http-system-timezone.out
grep -q '"applied":true' /tmp/suvos-http-system-timezone.out
wget -q -O /tmp/suvos-http-system-datetime-utc.out http://suv.os/api/system/datetime
cat /tmp/suvos-http-system-datetime-utc.out
grep -q '"configuredTimezone":"UTC"' /tmp/suvos-http-system-datetime-utc.out
wget -q -O /tmp/suvos-http-system-time-format.out --post-data='' 'http://suv.os/api/system/datetime/format?format=12h'
cat /tmp/suvos-http-system-time-format.out
grep -q '"ok":true' /tmp/suvos-http-system-time-format.out
grep -q '"format":"12h"' /tmp/suvos-http-system-time-format.out
wget -q -O /tmp/suvos-http-system-ntp.out http://suv.os/api/system/datetime/ntp
cat /tmp/suvos-http-system-ntp.out
grep -q '"ok":true' /tmp/suvos-http-system-ntp.out
wget -q -O /tmp/suvos-http-system-ntp-set.out --post-data='' 'http://suv.os/api/system/datetime/ntp?enabled=true&server=pool.ntp.org'
cat /tmp/suvos-http-system-ntp-set.out
grep -q '"ok":true' /tmp/suvos-http-system-ntp-set.out
wget -q -O /tmp/suvos-http-system-power.out http://suv.os/api/system/power
cat /tmp/suvos-http-system-power.out
grep -q '"ok":true' /tmp/suvos-http-system-power.out
grep -q '"battery":' /tmp/suvos-http-system-power.out
wget -q -O /tmp/suvos-http-system-power-configure.out --post-data='' 'http://suv.os/api/system/power/configure?profile=balanced&sleepTimeoutSeconds=0&blankScreenTimeoutSeconds=0'
cat /tmp/suvos-http-system-power-configure.out
grep -q '"ok":true' /tmp/suvos-http-system-power-configure.out
wget -q -O /tmp/suvos-http-system-storage.out http://suv.os/api/system/storage
cat /tmp/suvos-http-system-storage.out
grep -q '"ok":true' /tmp/suvos-http-system-storage.out
grep -q '"safeCleanupTargets":' /tmp/suvos-http-system-storage.out
mkdir -p /data/suvos/cache/autotest
printf 'cache-test\n' >/data/suvos/cache/autotest/sample.txt
wget -q -O /tmp/suvos-http-system-storage-cleanup.out --post-data='' 'http://suv.os/api/system/storage/cleanup?target=cache'
cat /tmp/suvos-http-system-storage-cleanup.out
grep -q '"ok":true' /tmp/suvos-http-system-storage-cleanup.out
test ! -e /data/suvos/cache/autotest/sample.txt
wget -q -O /tmp/suvos-http-system-versions.out http://suv.os/api/system/versions
cat /tmp/suvos-http-system-versions.out
grep -q '"ok":true' /tmp/suvos-http-system-versions.out
grep -q '"suvos":' /tmp/suvos-http-system-versions.out
wget -q -O /tmp/suvos-http-system-logs.out http://suv.os/api/system/logs
cat /tmp/suvos-http-system-logs.out
grep -q '"ok":true' /tmp/suvos-http-system-logs.out
wget -q -O /tmp/suvos-http-system-logging.out --post-data='' 'http://suv.os/api/system/logging?level=debug'
cat /tmp/suvos-http-system-logging.out
grep -q '"ok":true' /tmp/suvos-http-system-logging.out
grep -q '"level":"debug"' /tmp/suvos-http-system-logging.out
wget -q -O /tmp/suvos-http-notifications-clear-start.out --post-data='' http://suv.os/api/notifications/clear
cat /tmp/suvos-http-notifications-clear-start.out
grep -q '"ok":true' /tmp/suvos-http-notifications-clear-start.out
wget -q -O /tmp/suvos-http-calendar-clear-start.out --post-data='' http://suv.os/api/calendar/events/clear
cat /tmp/suvos-http-calendar-clear-start.out
grep -q '"ok":true' /tmp/suvos-http-calendar-clear-start.out
wget -q -O /tmp/suvos-http-notification-create.out --post-data='' 'http://suv.os/api/notifications/create?source=system&origin=suvos.system&type=info&title=ManualNotice&body=Hello'
cat /tmp/suvos-http-notification-create.out
grep -q '"ok":true' /tmp/suvos-http-notification-create.out
grep -q '"title":"ManualNotice"' /tmp/suvos-http-notification-create.out
notification_id="$(sed -n 's/.*"id":"\([^"]*\)".*/\1/p' /tmp/suvos-http-notification-create.out)"
test -n "$notification_id"
wget -q -O /tmp/suvos-http-notification-list.out 'http://suv.os/api/notifications?source=system&sort=created&order=desc&limit=5'
cat /tmp/suvos-http-notification-list.out
grep -q '"ok":true' /tmp/suvos-http-notification-list.out
grep -q '"notifications":' /tmp/suvos-http-notification-list.out
grep -q '"ManualNotice"' /tmp/suvos-http-notification-list.out
wget -q -O /tmp/suvos-http-notification-get.out "http://suv.os/api/notifications?id=$notification_id"
cat /tmp/suvos-http-notification-get.out
grep -q '"count":1' /tmp/suvos-http-notification-get.out
grep -q "\"id\":\"$notification_id\"" /tmp/suvos-http-notification-get.out
wget -q -O /tmp/suvos-http-notification-update.out --post-data='' "http://suv.os/api/notifications/update?id=$notification_id&body=UpdatedBody"
cat /tmp/suvos-http-notification-update.out
grep -q '"ok":true' /tmp/suvos-http-notification-update.out
grep -q '"body":"UpdatedBody"' /tmp/suvos-http-notification-update.out
wget -q -O /tmp/suvos-http-notification-clear-body.out --post-data="id=$notification_id&body=" http://suv.os/api/notifications/update
cat /tmp/suvos-http-notification-clear-body.out
grep -q '"ok":true' /tmp/suvos-http-notification-clear-body.out
grep -q '"body":""' /tmp/suvos-http-notification-clear-body.out
wget -q -O /tmp/suvos-http-notification-read.out --post-data='' "http://suv.os/api/notifications/read?id=$notification_id"
cat /tmp/suvos-http-notification-read.out
grep -q '"ok":true' /tmp/suvos-http-notification-read.out
grep -q '"status":"read"' /tmp/suvos-http-notification-read.out
wget -q -O /tmp/suvos-http-notification-dismiss.out --post-data='' "http://suv.os/api/notifications/dismiss?id=$notification_id"
cat /tmp/suvos-http-notification-dismiss.out
grep -q '"ok":true' /tmp/suvos-http-notification-dismiss.out
grep -q '"status":"dismissed"' /tmp/suvos-http-notification-dismiss.out
wget -q -O /tmp/suvos-http-notification-delete.out --post-data='' "http://suv.os/api/notifications/delete?id=$notification_id"
cat /tmp/suvos-http-notification-delete.out
grep -q '"ok":true' /tmp/suvos-http-notification-delete.out
grep -q '"deleted":1' /tmp/suvos-http-notification-delete.out
wget -q -O /tmp/suvos-http-notification-policy-set.out --post-data='' 'http://suv.os/api/notifications/policy/set?targetType=site&target=blocked.test&allowed=false'
cat /tmp/suvos-http-notification-policy-set.out
grep -q '"ok":true' /tmp/suvos-http-notification-policy-set.out
grep -q '"allowed":false' /tmp/suvos-http-notification-policy-set.out
wget -q -O /tmp/suvos-http-notification-policy.out http://suv.os/api/notifications/policy
cat /tmp/suvos-http-notification-policy.out
grep -q '"target":"blocked.test"' /tmp/suvos-http-notification-policy.out
wget -q -O /tmp/suvos-http-notification-blocked.out --post-data='' 'http://suv.os/api/notifications/create?source=site&origin=blocked.test&type=info&title=BlockedNotice&body=Nope'
cat /tmp/suvos-http-notification-blocked.out
grep -q '"ok":true' /tmp/suvos-http-notification-blocked.out
grep -q '"blocked":true' /tmp/suvos-http-notification-blocked.out
wget -q -O /tmp/suvos-http-notification-quiet-on.out --post-data='' 'http://suv.os/api/notifications/quiet?enabled=true'
cat /tmp/suvos-http-notification-quiet-on.out
grep -q '"ok":true' /tmp/suvos-http-notification-quiet-on.out
wget -q -O /tmp/suvos-http-notification-quiet-create.out --post-data='' 'http://suv.os/api/notifications/create?source=system&origin=suvos.system&type=info&title=QuietNotice&body=Silent'
cat /tmp/suvos-http-notification-quiet-create.out
grep -q '"status":"quiet"' /tmp/suvos-http-notification-quiet-create.out
wget -q -O /tmp/suvos-http-notification-unread-count.out 'http://suv.os/api/notifications/unread-count?source=system'
cat /tmp/suvos-http-notification-unread-count.out
grep -q '"ok":true' /tmp/suvos-http-notification-unread-count.out
grep -q '"unreadCount":' /tmp/suvos-http-notification-unread-count.out
wget -q -O /tmp/suvos-http-notification-quiet-clear.out --post-data='' 'http://suv.os/api/notifications/clear?status=quiet'
cat /tmp/suvos-http-notification-quiet-clear.out
grep -q '"ok":true' /tmp/suvos-http-notification-quiet-clear.out
wget -q -O /tmp/suvos-http-notification-quiet-off.out --post-data='' 'http://suv.os/api/notifications/quiet?enabled=false'
cat /tmp/suvos-http-notification-quiet-off.out
grep -q '"ok":true' /tmp/suvos-http-notification-quiet-off.out
now_epoch="$(date +%s)"
due_epoch=$((now_epoch - 5))
wget -q -O /tmp/suvos-http-calendar-create.out --post-data='' "http://suv.os/api/calendar/events/create?source=calendar&origin=suvos.calendar&type=goal&title=DailyGoal&description=DoThing&startEpoch=$due_epoch&endEpoch=$due_epoch"
cat /tmp/suvos-http-calendar-create.out
grep -q '"ok":true' /tmp/suvos-http-calendar-create.out
grep -q '"title":"DailyGoal"' /tmp/suvos-http-calendar-create.out
event_id="$(sed -n 's/.*"id":"\([^"]*\)".*/\1/p' /tmp/suvos-http-calendar-create.out)"
test -n "$event_id"
wget -q -O /tmp/suvos-http-calendar-update.out --post-data='' "http://suv.os/api/calendar/events/update?id=$event_id&meta=priority-high"
