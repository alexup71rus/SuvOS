#!/bin/sh

set -eu

SUVOS_WITH_RUNTIMES=1
SUVOS_BUILD_PROFILE=full
if [ -r /system/suvos/config/build.conf ]; then
  . /system/suvos/config/build.conf
fi

echo "SUVOS_AUTOTEST_BEGIN"
echo "profile=$SUVOS_BUILD_PROFILE"
echo "pwd=$(pwd)"
suvos ping
suvos status
suvos roles
suvos whoami
suvos auth status
suvos-splash --check
test -s /system/suvos/security/root-bootstrap.sha256
test -d /system/suvos/apps/manifest.d
test -S /run/suvosd/control.sock
suvosctl ping
suvosctl whoami
suvosctl list
suvosctl run hello
wget -q -O /tmp/suvos-http-health.out http://127.0.0.1:8080/health
cat /tmp/suvos-http-health.out
grep -q '"ok":true' /tmp/suvos-http-health.out
wget -q -O /tmp/suvos-ui-index.out http://127.0.0.1:8080/
grep -q '<title>SuvOS Settings</title>' /tmp/suvos-ui-index.out
wget -q -O /tmp/suvos-ui-js.out http://127.0.0.1:8080/ui/app.js
grep -q '/api/status' /tmp/suvos-ui-js.out
if find /system/suvos/ui -type f -name '*.ts' | grep -q .; then
  echo "typescript UI sources are present in image"
  exit 1
fi
wget -q -O /tmp/suvos-ui-css.out http://127.0.0.1:8080/ui/styles.css
grep -q '.panel' /tmp/suvos-ui-css.out
wget -q -O /tmp/suvos-http-status.out http://127.0.0.1:8080/api/status
cat /tmp/suvos-http-status.out
grep -q '"status":"booted"' /tmp/suvos-http-status.out
grep -q '"systemRootReadOnly":true' /tmp/suvos-http-status.out
grep -q '"apiSocketAvailable":true' /tmp/suvos-http-status.out
wget -q -O /tmp/suvos-http-roles.out http://127.0.0.1:8080/api/roles
cat /tmp/suvos-http-roles.out
grep -q '"currentRole":"setup"' /tmp/suvos-http-roles.out
grep -q '"permissions":' /tmp/suvos-http-roles.out
wget -q -O /tmp/suvos-http-apps.out http://127.0.0.1:8080/api/apps
cat /tmp/suvos-http-apps.out
grep -q '"apps":' /tmp/suvos-http-apps.out
grep -q '"name":"hello"' /tmp/suvos-http-apps.out
wget -q -O /tmp/suvos-http-run.out 'http://127.0.0.1:8080/api/run?name=hello'
cat /tmp/suvos-http-run.out
grep -q '"exitCode":0' /tmp/suvos-http-run.out
grep -q 'shell' /tmp/suvos-http-run.out
if suvos auth root wrong-bootstrap-secret >/tmp/suvos-auth-test.out 2>&1; then
  echo "invalid root bootstrap secret was accepted"
  exit 1
fi
cat /tmp/suvos-auth-test.out
suvos list
if touch /system/suvos/.rw-test >/tmp/suvos-ro-test.out 2>&1; then
  echo "system root is writable"
  rm -f /system/suvos/.rw-test
  exit 1
fi
echo "SYSTEM_RO_PASS"
echo "data-root-test" >/data/suvos/tmp/rw-test.txt
cat /data/suvos/tmp/rw-test.txt
echo "DATA_RW_PASS"
mkdir -p /tmp/suvos-test
cd /tmp/suvos-test
echo "created-by-autotest" > sample.txt
ls -la
cat sample.txt
suvos run hello
suvos run cpp-hello
if [ "$SUVOS_WITH_RUNTIMES" = "1" ]; then
  python3 --version
  node --version
  suvos run py-hello
  suvos run node-hello
else
  if suvos run py-hello >/tmp/suvos-runtime-disabled.out 2>&1; then
    echo "runtime app was available in core profile"
    exit 1
  fi
  cat /tmp/suvos-runtime-disabled.out
  echo "RUNTIME_TESTS_SKIPPED"
fi
if suvos run ../init >/tmp/suvos-invalid-run.out 2>&1; then
  echo "invalid app name was not blocked"
  exit 1
fi
cat /tmp/suvos-invalid-run.out
echo "SUVOS_AUTOTEST_PASS"
