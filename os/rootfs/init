#!/bin/sh
export PATH=/system/suvos/bin:/opt/suvos/bin:/bin:/sbin:/usr/bin:/usr/sbin
export HOME=/root
export USER=root
export SHELL=/system/suvos/bin/suvos-shell

if [ -r /system/suvos/config/locale.conf ]; then
  . /system/suvos/config/locale.conf
  export SUVOS_LANG="${SUVOS_LANG:-ru}"
fi

mount -t proc proc /proc 2>/dev/null || true
mount -t sysfs sysfs /sys 2>/dev/null || true
mount -t devtmpfs devtmpfs /dev 2>/dev/null || true

mkdir -p /dev /proc /sys /tmp /run /root /data

exec </dev/console >/dev/console 2>&1

/bin/busybox --install -s /bin 2>/dev/null || true

prepare_data_root() {
  mount -t tmpfs -o mode=0755,size=64m suvos-data /data 2>/tmp/suvos-data.err || true

  mkdir -p /data/suvos
  mkdir -p /data/suvos/apps
  mkdir -p /data/suvos/extensions
  mkdir -p /data/suvos/state
  mkdir -p /data/suvos/logs
  mkdir -p /data/suvos/tmp

  chmod 0755 /data /data/suvos /data/suvos/apps /data/suvos/extensions /data/suvos/logs
  chmod 0700 /data/suvos/state /data/suvos/tmp
}

make_system_readonly() {
  mount -o bind /system/suvos /system/suvos 2>/tmp/suvos-ro.err || {
    echo "[init] warning: cannot bind-mount /system/suvos read-only" >/dev/console
    cat /tmp/suvos-ro.err >/dev/console 2>/dev/null || true
    return 0
  }

  mount -o remount,ro,bind /system/suvos /system/suvos 2>/tmp/suvos-ro.err || \
    mount -o remount,ro /system/suvos 2>/tmp/suvos-ro.err || {
      echo "[init] warning: cannot remount /system/suvos read-only" >/dev/console
      cat /tmp/suvos-ro.err >/dev/console 2>/dev/null || true
      return 0
    }
}

prepare_data_root
make_system_readonly

if grep -qw 'suvos.graphics=1' /proc/cmdline 2>/dev/null; then
  /system/suvos/bin/suvos-load-graphics >/tmp/suvos-graphics.log 2>&1 || true
  cat /tmp/suvos-graphics.log >/dev/console 2>/dev/null || true
  /system/suvos/bin/suvos-splash --color '#116149' >/tmp/suvos-splash.log 2>&1 || true
  cat /tmp/suvos-splash.log >/dev/console 2>/dev/null || true
fi

clear 2>/dev/null || true
suvos-motd 2>/dev/null || cat /etc/motd 2>/dev/null || true

/system/suvos/bin/suvosd &

for _ in 1 2 3; do
  [ -p /run/suvosd/request ] && [ -S /run/suvosd/control.sock ] && break
  sleep 1
done

ifconfig lo 127.0.0.1 up 2>/tmp/suvos-lo.err || true
/system/suvos/bin/suvos-gateway &

for _ in 1 2 3 4 5; do
  wget -q -O /tmp/suvos-gateway-health http://127.0.0.1:8080/health >/dev/null 2>&1 && break
  sleep 1
done

if grep -qw 'suvos.autotest=1' /proc/cmdline 2>/dev/null; then
  /system/suvos/bin/suvos-autotest
  poweroff -f
fi

exec /system/suvos/bin/suvos-shell
